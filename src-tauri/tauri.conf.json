{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Praxishub Connector",
  "version": "0.1.0",
  "identifier": "ai.praxishub.connector",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Praxishub Connector",
        "width": 760,
        "height": 860,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "IntensivKontakt GmbH",
    "category": "Productivity",
    "shortDescription": "Brücke zwischen Praxishub und Ihrer Praxissoftware",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["German", "English"]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.praxishub.ai/api/v1/connector/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3MDBEMENFRThGQUU2MjMKUldRajV2cm96dEFBVjNXY2N2OENWcjBqdDh3b0g5cDFVWmVDOWJ6RFdrNjVvOEJISUxzTXF4dnYK"
    }
  }
}
